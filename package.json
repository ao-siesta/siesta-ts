{
  "name": "siesta-ts",
  "type": "module",
  "version": "5.0.2",
  "description": "",
  "author": "William Wong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ao-siesta/siesta-ts"
  },
  "keywords": [
    "discord",
    "bot"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^24.18.0",
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "lint:inspect": "eslint --inspect-config",
    "start": "tsx src/index.ts",
    "run": "nr start",
    "dev": "tsx watch src/index.ts",
    "prepare": "simple-git-hooks",
    "release": "nlx bumpp",
    "analyze": "nlx node-modules-inspector",
    "cmdreg": "tsx src/utils/cmdreg.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "axios": "^1.18.0",
    "discord.js": "^14.26.4",
    "node-cron": "^4.4.1",
    "random": "^5.4.1",
    "selenium-webdriver": "^4.45.0",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^30.1.0",
    "@oliver139/eslint-config": "^7.5.4",
    "@tsconfig/recommended": "1.0.13",
    "@types/node": "^24.13.2",
    "ansis": "^4.3.1",
    "eslint": "^10.5.0",
    "npm-check-updates": "^22.2.7",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.14.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "inlinedDependencies": {
    "ansis": "4.3.1"
  }
}
